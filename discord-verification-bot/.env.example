# Discord Bot Configuration
# Get your bot token from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Discord Application ID (Client ID)
# Found in the same page as your bot token
CLIENT_ID=your_client_id_here

# Server/Guild ID (for slash commands)
# Right-click your server name and "Copy Server ID" (Enable Developer Mode first)
GUILD_ID=your_guild_id_here

# Role Configuration
# The ID of the role to assign when verified
VERIFIED_ROLE_ID=your_verified_role_id_here

# The ID of the role that unverified users get (optional)
UNVERIFIED_ROLE_ID=your_unverified_role_id_here

# Channel Configuration
# Channel where verification messages will be sent
VERIFY_CHANNEL_ID=your_verify_channel_id_here

# Channel for verification logs
LOG_CHANNEL_ID=your_log_channel_id_here

# Verification Settings
# Time in minutes before auto-kicking unverified users (0 = disabled)
AUTO_KICK_MINUTES=30

# Enable captcha verification (true/false)
ENABLE_CAPTCHA=true

# Cooldown in seconds between verification attempts
VERIFICATION_COOLDOWN=10

# Admin/Moderator Role IDs (comma separated)
ADMIN_ROLE_IDS=admin_role_id_1,admin_role_id_2
